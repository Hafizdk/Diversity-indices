# Species total counts
mosquito_counts <- c(
  Ae_aegypti = 1,
  Ae_albopictus = 154,
  An_lvcraeus = 26,
  An_umbrosus = 5,
  Armigeres_kesseli = 13,
  Ar_subalbatus = 678,
  An_sundaicus = 3,
  Cx_vishnui = 281,
  Mansonia_uniformis = 40,
  Coquillettidia = 12,
  Cx_quinquefasciatus = 153,
  Cx_sitiens = 31,
  Ae_butleri = 133,
  Cx_gelidus = 47,
  Cx_tritaeniorhynchus = 4,
  Cx_sinensis = 3
)
library(vegan)
# Shannon Index
H <- diversity(mosquito_counts, index = "shannon")
print(paste("Shannon-Wiener Index (H'):", round(H, 3)))
# Species Richness (S)
S <- specnumber(mosquito_counts)
# Shannon Evenness Index (Pielou's J)
J <- H / log(S)
# Display the results
cat("Shannon-Wiener Diversity Index (H′):", round(H, 3), "\n")
cat("Species Richness (S):", S, "\n")
cat("Shannon Evenness Index (J):", round(J, 3), "\n")
library (vegan)
# Simpson's Index (D)
D <- diversity(mosquito_counts, index = "simpson")
# Calculate Simpson's Diversity Index (1 - D)
simpson_diversity <- 1 - D

# Display the result
cat("Simpson's Diversity Index (1 - D):", round(simpson_diversity, 3), "\n")
# Berger-Parker Index (d)
d <- max(mosquito_counts) / sum(mosquito_counts)
print(paste("Berger-Parker Dominance Index:", round(d, 3)))
